{
  "buildCommand": "pnpm --filter @workspace/ca-firm run build",
  "outputDirectory": "artifacts/ca-firm/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
